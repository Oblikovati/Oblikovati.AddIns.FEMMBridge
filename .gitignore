# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
test-results-*.xml

# Go workspace file (local-dev only: resolves the sibling Oblikovati/Oblikovati.API
# checkouts; CI injects the equivalent `go mod edit -replace` instead).
go.work
go.work.sum

# env file
.env

# The c-shared library build output (Makefile writes here).
/build/

# C ABI header vendored from the oblikovati.org/api module by `make sync-header`.
/include/

# Built CLI driver binaries (go build ./cmd/femm... drops them at the repo root).
/femm*

# Vendored FEMM solver sources / build (Phase 2a).
/vendor-src/**/build/
/vendor-src/femm/build/
